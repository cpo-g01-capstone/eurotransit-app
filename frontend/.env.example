# Dev-only: where the Vite proxy forwards /api requests.
# Point it at a local backend (e.g. http://localhost:8082 won't work — you need
# a gateway serving /catalog and /orders together; the deployed cluster does)
# or leave unset to use the live cluster.
#
# SECURITY (07b): VITE_* variables are compiled into the public JS bundle.
# Never put API keys, passwords, or any secret here.
VITE_DEV_PROXY_TARGET=https://eurotransit.vojtechn.dev
